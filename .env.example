# AWS Configuration
# Uses default AWS credentials chain (profile, env vars, or IAM role on Amplify)
# If running locally, ensure your ~/.aws/credentials has valid keys
AWS_REGION=us-east-1

# Amazon Bedrock — LLM for guardrailed Q&A
# Use inference profile ID (not raw model ID) for on-demand access
BEDROCK_MODEL_ID=us.anthropic.claude-opus-4-6-v1
BEDROCK_GUARDRAIL_ID=your_guardrail_id
BEDROCK_GUARDRAIL_VERSION=DRAFT

# Apify — Review scraper (primary)
# Sign up at https://apify.com, copy your Personal API Token
APIFY_API_TOKEN=your_apify_api_token
