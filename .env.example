# AWS Configuration
# Locally: SDK uses ~/.aws/credentials automatically (run `aws configure` to set up)
# On Amplify: No credentials file exists, so explicit keys are required.
#             Set MY_AWS_ACCESS_KEY_ID and MY_AWS_SECRET_ACCESS_KEY in Amplify Console
#             (Amplify blocks the AWS_ prefix — amplify.yml remaps them at build time)
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=     # Only needed if ~/.aws/credentials is not configured
# AWS_SECRET_ACCESS_KEY= # Only needed if ~/.aws/credentials is not configured

# Amazon Bedrock — LLM for guardrailed Q&A
# Use inference profile ID (not raw model ID) for on-demand access
BEDROCK_MODEL_ID=us.anthropic.claude-opus-4-6-v1
BEDROCK_GUARDRAIL_ID=your_guardrail_id
BEDROCK_GUARDRAIL_VERSION=DRAFT

# Apify — Review scraper (primary)
# Sign up at https://apify.com, copy your Personal API Token
APIFY_API_TOKEN=your_apify_api_token
